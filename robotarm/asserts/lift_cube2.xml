<mujoco model="low_cost_robot scene">
  <!-- The timestep has a big influence on the contacts stability -->
  <option cone="elliptic" impratio="10" timestep="0.25"/>
  
  <include file="test4.xml"/>
  
  <statistic center="0 0 0.1" extent="0.6"/>
  
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20" offheight="640"/>
  </visual>
  
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
    markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>
  
  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="false"/>
    <geom name="floor" size="10 10 0.05" type="plane" material="groundplane" pos="0 0 0" friction="1.0" contype="1" conaffinity="1"/> <!-- 增大地面的摩擦力 -->
      <body name="cylinder" pos="-0.5 0.0 0.1">
          <!-- 调整圆柱体的初始位置 -->
          <freejoint name="red_cylinder_joint"/>
          
          <!-- 增加圆柱体的质量，使其更稳定 -->
          <inertial pos="0 0 0" mass="10000.0" diaginertia="0.05 0.05 0.05"/> <!-- 进一步增加惯性矩，确保稳定性 -->
          
          <!-- 增加摩擦力，调整碰撞参数 -->
          <geom type="cylinder" size="0.03 0.1" pos="0 0 0" rgba="1 0 0 1" 
                friction="0.5" condim="4" name="red_cylinder" priority="1" contype="1" conaffinity="10"
                /> <!-- 大幅降低solimp和solref，减少反弹 -->
      </body>




    <camera name="camera_front" pos="0.049 0.5 0.225" xyaxes="-0.998 0.056 -0.000 -0.019 -0.335 0.942"/>
    <camera name="camera_top" pos="0 0.1 0.6" euler="0 0 0" mode="fixed"/>
    <camera name="camera_vizu" pos="-0.1 0.6 0.3" quat="-0.15 -0.1 0.6 1"/>
  </worldbody>
  

</mujoco>